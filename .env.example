# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# MongoDB Connection (get free from mongodb.com/atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/aryemanone

# JWT Secret (any random long string)
JWT_SECRET=your-super-secret-key-change-this-123456

# Port (Vercel handles this automatically)
PORT=3000

# App URL (your Vercel URL after deploy)
APP_URL=https://aryemanone.vercel.app

# Anthropic API Key (for Zia AI - get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...
